{"true_np": "1.5.1.3.3", "true_header": "That it shall give access to the  confidential  information only,", "max_recall": 0.9666666666666667, "max_precision": 0.3670886075949367, "max_f1": 0.5321100917431193, "max_recall_np": "5.1.3", "max_precision_np": "5.1.3", "max_f1_np": "5.1.3"}
{"true_np": "1.5.1.3.4", "true_header": "That it shall  not copy or reproduce  in any form  any of the confidential information  disclosed  to it by the  disclosing  party,", "max_recall": 0.9615384615384616, "max_precision": 0.31645569620253167, "max_f1": 0.47619047619047616, "max_recall_np": "5.1.3", "max_precision_np": "5.1.3", "max_f1_np": "5.1.3"}
