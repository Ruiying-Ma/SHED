o tapes, video tapes, computer discs, machines, prototypes, designs, specifications,\narticles of manufacture, drawings, human or machine readable documents. Confidential Information shall also include all information related to the Invention provided by Disclosing Party to Receiving Party prior to the signing\nConfidentiality and Non-Disclosure Agreement\nPage 1", "mimetype": "text/plain", "start_char_idx": 979, "end_char_idx": 1503, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "9bb42b0a-728c-4390-a76d-00f8a2b638c4": {"__data__": {"id_": "9bb42b0a-728c-4390-a76d-00f8a2b638c4", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "8d1431b8-8436-43ab-aa4e-f67eb1448bbe", "node_type": "4", "metadata": {}, "hash": "4c683a94ea810b151b5bc7a1738bc5cd9947edc5f54db75997ace58c567158a7", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8f09cc02-b523-4aad-989e-9414e6f21763", "node_type": "1", "metadata": {}, "hash": "8aa35ed9a9e02d6a645feef1aa2f379d1001014d0092b6e8fab6de9d8cef36b2", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "73856536-ee0f-4717-b5e3-f213ac3dd3ad", "node_type": "1", "metadata": {}, "hash": "ef8dfb74e92e9d46cfed8fb1620db31e38cde295fb5f474f5f3e04b3ab63e715", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "of this agreement.  Confidential Information shall not include any information in the public domain at the time of the disclosure, or subsequently comes within the public domain without fault of the Receiving Party.\n\n2.", "mimetype": "text/plain", "start_char_idx": 1506, "end_char_idx": 1725, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "73856536-ee0f-4717-b5e3-f213ac3dd3ad": {"__data__": {"id_": "73856536-ee0f-4717-b5e3-f213ac3dd3ad", "embedding": null,