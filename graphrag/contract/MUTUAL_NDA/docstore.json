316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "c34602f5-2ac6-4d6b-b000-36022acd446d", "node_type": "1", "metadata": {}, "hash": "9f4433d131c35003f24ead216edcc4693ee9b6512ff5809ffb3db897dee7cdd6", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "2e3c6691-7bc3-4f21-a8d5-dc6113e42b25", "node_type": "1", "metadata": {}, "hash": "8b04a6b7749da49a0d7c71f4b26c1df3affadc01c6bfded87619491476ebd473", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "provided that information disclosed by the Disclosing Party will be considered Confidential Information by the Receiving Party only if such information is conspicuously designated as \"Confidential\" (i) in writing, if communicated in writing, or (ii) confirmed in writing within thirty (30) days of disclosure, if disclosed orally or in other non-tangible form;", "mimetype": "text/plain", "start_char_idx": 901, "end_char_idx": 1261, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "2e3c6691-7bc3-4f21-a8d5-dc6113e42b25": {"__data__": {"id_": "2e3c6691-7bc3-4f21-a8d5-dc6113e42b25", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "5a7161fd-e4a2-4758-a520-46f218d9c201", "node_type": "1", "metadata": {}, "hash": "28513e144b5b1622b409e600d69842177d2fa65884eefc29cca3686343a52567", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "dd42028e-a420-4cca-99ed-51724bd3ed95", "node_type": "1", "metadata": {}, "hash": "3c202de08f7b73121705f579663e17bee2aa6f5018a56211debe35cea1010b33", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "and provided further that Confidential Information shall not include information that (A) is now or subsequently becomes generally available to the public through no fault or breach on the part of the Receiving Party; (B) the Receiving Party can demonstrate to have had rightfully in its possession prior to disclosure to the Receiving Party by the Disclosing Party; (C) is independently developed by the Receiving Party without the use of any Confidential Information;", "mimetype": "text/plain", "start_char_idx": 1262, "end_char_idx": 1731, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "dd42028e-a420-4cca-99ed-51724bd3ed95": {"__data__": {"id_": "dd42028e-a420-4cca-99ed-51724bd3ed95", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "2e3c6691-7bc3-4f21-a8d5-dc6113e42b25", "node_type": "1", "metadata": {}, "hash": "8b04a6b7749da49a0d7c71f4b26c1df3affadc01c6bfded87619491476ebd473", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "6d6667e1-a58d-4322-a995-377acf820d78", "node_type": "1", "metadata": {}, "hash": "3a44dc5d718f1396ab21dbe12bef61859eef99cfd3400a871fbb728c3e5600ed", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "or (D) the Receiving Party rightfully obtains from a third party who has the right to transfer or disclose it.\n\n2. Non-Disclosure and Non-Use of Confidential Information .", "mimetype": "text/plain", "start_char_idx": 1732, "end_char_idx": 1903, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "6d6667e1-a58d-4322-a995-377acf820d78": {"__data__": {"id_": "6d6667e1-a58d-4322-a995-377acf820d78", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "dd42028e-a420-4cca-99ed-51724bd3ed95", "node_type": "1", "metadata": {}, "hash": "3c202de08f7b73121705f579663e17bee2aa6f5018a56211debe35cea1010b33", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e839ff1e-bd40-48c7-a3d7-00d05c0514a7", "node_type": "1", "metadata": {}, "hash": "f2daf6dbbd8d24dd1b5721fa5f0ab48d8ad686b21d01e77711764f7d0dbbf5e3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Receiving Party shall not, without the prior written approval of the Disclosing Party in each instance or unless otherwise expressly permitted in this Agreement, use for its own benefit, publish or otherwise disclose to others, or permit the use by others for their benefit or to the detriment of the Disclosing Party, any of the Confidential Information.", "mimetype": "text/plain", "start_char_idx": 1906, "end_char_idx": 2265, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e839ff1e-bd40-48c7-a3d7-00d05c0514a7": {"__data__": {"id_": "e839ff1e-bd40-48c7-a3d7-00d05c0514a7", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "6d6667e1-a58d-4322-a995-377acf820d78", "node_type": "1", "metadata": {}, "hash": "3a44dc5d718f1396ab21dbe12bef61859eef99cfd3400a871fbb728c3e5600ed", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "631a690d-6c32-4e1d-a28b-ec7940545c61", "node_type": "1", "metadata": {}, "hash": "f202440f0019a2b820318a54d2f4a96f13e147101ad554f8b6fe6a54ffb6c6f5", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Receiving Party shall carefully restrict access to the Confidential Information to those of its officers, directors and employees who clearly need such access in order to participate on behalf of the Receiving Party in the analysis and negotiation of a business relationship or any contract or agreement, or the advisability thereof, with the Disclosing Party and who are bound by written confidentiality agreements that protect third party information.\n\n The Receiving Party may disclose Confidential Information if required by a judicial or governmental request, requirement or order;", "mimetype": "text/plain", "start_char_idx": 2268, "end_char_idx": 2858, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "631a690d-6c32-4e1d-a28b-ec7940545c61": {"__data__": {"id_": "631a690d-6c32-4e1d-a28b-ec7940545c61", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e839ff1e-bd40-48c7-a3d7-00d05c0514a7", "node_type": "1", "metadata": {}, "hash": "f2daf6dbbd8d24dd1b5721fa5f0ab48d8ad686b21d01e77711764f7d0dbbf5e3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "17531f3e-8fee-4570-88d2-ffba9ed04e2c", "node_type": "1", "metadata": {}, "hash": "97bbb5da9116bc1bdce249bab01a2180cf7b386edbc57bb8622fc5854e491d19", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "provided that the Receiving Party will take reasonable steps to give the Disclosing Party sufficient prior notice of such request, requirement or order for the Disclosing Party to contest, limit or protect such disclosure.P a g e | 1\nMutual Non-Disclosure Agreement: Page 2 Initials ______\n\nMUTUAL NON-DISCLOSURE AGREEMENT\n\nP a g e | 2\nMutual Non-Disclosure Agreement: Page 2 Initials ______\n\n3.", "mimetype": "text/plain", "start_char_idx": 2859, "end_char_idx": 3254, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "17531f3e-8fee-4570-88d2-ffba9ed04e2c": {"__data__": {"id_": "17531f3e-8fee-4570-88d2-ffba9ed04e2c", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "631a690d-6c32-4e1d-a28b-ec7940545c61", "node_type": "1", "metadata": {}, "hash": "f202440f0019a2b820318a54d2f4a96f13e147101ad554f8b6fe6a54ffb6c6f5", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "a759eae0-4777-4c2d-91d9-004d552080b0", "node_type": "1", "metadata": {}, "hash": "f05fd2e23c9aacc414001b955ca5e0070ba0d4e8669bb01a1cc7719a113eb1f7", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Ownership of Confidential Information .\n\n All Confidential Information and all intellectual property rights therein shall remain the property of the Disclosing Party and no license or other right to Confidential Information is granted or implied hereby.\n\n4. Term.\n\n The term of this Agreement is two (2) years from the Effective Date, provided that the Receiving Party's duty to protect the Disclosing Party's Confidential Information shall survive expiration or termination of this Agreement and shall expire five (2) years from the date of disclosure.", "mimetype": "text/plain", "start_char_idx": 3255, "end_char_idx": 3808, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a759eae0-4777-4c2d-91d9-004d552080b0": {"__data__": {"id_": "a759eae0-4777-4c2d-91d9-004d552080b0", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "17531f3e-8fee-4570-88d2-ffba9ed04e2c", "node_type": "1", "metadata": {}, "hash": "97bbb5da9116bc1bdce249bab01a2180cf7b386edbc57bb8622fc5854e491d19", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "8ac4afdd-036b-4379-b89f-01e4375e6661", "node_type": "1", "metadata": {}, "hash": "dd363cbbf2f75a5f7d5a7913c06f1d0b146fbc3723c5e941156ba92007e22e53", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "5. Injunctive Relief.\n\n The Receiving Party understands and acknowledges that any disclosure or misappropriation of any of the Confidential Information in violation of this Agreement may cause the Disclosing Party irreparable harm, the amount of which may be difficult to ascertain and, therefore,", "mimetype": "text/plain", "start_char_idx": 3810, "end_char_idx": 4107, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "8ac4afdd-036b-4379-b89f-01e4375e6661": {"__data__": {"id_": "8ac4afdd-036b-4379-b89f-01e4375e6661", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "a759eae0-4777-4c2d-91d9-004d552080b0", "node_type": "1", "metadata": {}, "hash": "f05fd2e23c9aacc414001b955ca5e0070ba0d4e8669bb01a1cc7719a113eb1f7", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "d4a299aa-d693-4206-aa83-c7f6aab7891b", "node_type": "1", "metadata": {}, "hash": "98873f4d5ed9603fba11f4b86ace1d515d0e9b36643d25de73aceb01ed2f93a1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "agrees that the Disclosing Party shall have the right to apply to a court of competent jurisdiction for an order restraining any such further disclosure or misappropriation and for such other relief as the Disclosing Party shall deem appropriate, such right of the Disclosing Party to be in addition to the remedies otherwise available to the Disclosing Party at law or in equity.\n\n6. Return of Confidential Information .", "mimetype": "text/plain", "start_char_idx": 4108, "end_char_idx": 4529, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d4a299aa-d693-4206-aa83-c7f6aab7891b": {"__data__": {"id_": "d4a299aa-d693-4206-aa83-c7f6aab7891b", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "63ee324e-3b5b-4651-a131-7f676cab5fd4", "node_type": "4", "metadata": {}, "hash": "def1ef875ce128edae53311eca1eb5e4a1ad64fcaab970a4d0884e316be6c829", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8ac4afdd-036b-4379-b89f-01e4375e6661", "node_type": "1", "metadata": {}, "hash": "dd363cbbf2f75a5f7d5a7913c06f1d0b146fbc3723c5e941156ba92007e22e53", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "70846db4-93ab-484b-9801-378f036a94c7", "node_type": "1", "metadata": {}, "hash": "2480a66f5e8d184d3c38c7c2412533c656fc152629f329604bd9a0dc628779c8", "class_name": "RelatedNodeInfo"}}, "metadata_te