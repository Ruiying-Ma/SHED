e": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "8f978648-bd6d-406b-9f37-c021695028b8", "node_type": "1", "metadata": {}, "hash": "a0700b80e328fe2745dff039e21d1c7f4a82487b130799f3a5730c0e03b9623d", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "1e03e453-5839-4da9-89aa-84b96ac42524", "node_type": "1", "metadata": {}, "hash": "30579b6da812a6b0b16be5da519a42ced597d95a207165934e18ef98e880f75b", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "3 91054 ERLANGEN, GERMANY\nand\nand is e \ufb00 ective as of the last date signed.The parties agree that in order for them to explore opportunities and examine how they might work together to their mutual benefit, it will be necessary and desirable that they disclose confidential business information.\n\nThe  parties  agree  to  protect  each  other's  Confidential  Information  disclosed  before  or after the execution of this Agreement on the following terms.", "mimetype": "text/plain", "start_char_idx": 133, "end_char_idx": 589, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1e03e453-5839-4da9-89aa-84b96ac42524": {"__data__": {"id_": "1e03e453-5839-4da9-89aa-84b96ac42524", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "5930bfd3-78e8-4c7c-8bb2-1f229efa559d", "node_type": "1", "metadata": {}, "hash": "8b4fd649c2dd9c3b693606d1abb0f5b41edaf1573e8bd1c6ae2de4a5d8c8a4df", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "5c7f62c1-dda2-4ae9-862d-9e5bca00b6da", "node_type": "1", "metadata": {}, "hash": "22e8a55ffe5382bede6106aad51692b9eb3086cf2cec2b6aaac75efa15eac513", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "1.\n\n Each  party  shall  use  its  reasonable  best  e \ufb00 orts  to  keep  the  other's  Confidential Information  secret.  Each  party  shall  use  at  least  the  same  degree  of  care  to  avoid unauthorized  disclosure  or  use  of  the  other's  Confidential  Information  as  it  employs with respect to its own Confidential Information of like importance.", "mimetype": "text/plain", "start_char_idx": 591, "end_char_idx": 952, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "5c7f62c1-dda2-4ae9-862d-9e5bca00b6da": {"__data__": {"id_": "5c7f62c1-dda2-4ae9-862d-9e5bca00b6da", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "1e03e453-5839-4da9-89aa-84b96ac42524", "node_type": "1", "metadata": {}, "hash": "30579b6da812a6b0b16be5da519a42ced597d95a207165934e18ef98e880f75b", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "dd73aa8f-31d7-4bf5-87f8-204a6ff8ab29", "node_type": "1", "metadata": {}, "hash": "f008de771b9ee26c8da66ba163569abaf5f1bfef451564eaa4a39d560c372dc3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "2.\n\n Neither party has any obligation with respect to any Confidential Information which (a) that party independently develops without reference to the Confidential Information; (b) is or becomes publicly known without a breach of this Agreement by either party or is known prior to the date hereof; (c) is disclosed to it by a third person who is not\nrequired to maintain its confidentiality; (d) is approved for release by the other party in writing.", "mimetype": "text/plain", "start_char_idx": 954, "end_char_idx": 1406, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "dd73aa8f-31d7-4bf5-87f8-204a6ff8ab29": {"__data__": {"id_": "dd73aa8f-31d7-4bf5-87f8-204a6ff8ab29", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "5c7f62c1-dda2-4ae9-862d-9e5bca00b6da", "node_type": "1", "metadata": {}, "hash": "22e8a55ffe5382bede6106aad51692b9eb3086cf2cec2b6aaac75efa15eac513", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "74cf7d14-80b5-4d6b-80da-768f0b10377c", "node_type": "1", "metadata": {}, "hash": "4c6fc8041fde1c5b1ebb27842236db2d449fcc1c265a1bddcc750bf9d2ddaa2d", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The party claiming any of the above exceptions has the burden of proving its applicability.\n\n3.\n\n Each party may disclose Confidential Information only on a need-to-know basis to its own  employees  and  to  its  consultants  under  appropriate  written  burden  of confidentiality.  Each  party  shall  take  appropriate  action  with  its  employees  and advisors  to  satisfy  its  obligations  under  this  Agreement.", "mimetype": "text/plain", "start_char_idx": 1409, "end_char_idx": 1830, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "74cf7d14-80b5-4d6b-80da-768f0b10377c": {"__data__": {"id_": "74cf7d14-80b5-4d6b-80da-768f0b10377c", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "dd73aa8f-31d7-4bf5-87f8-204a6ff8ab29", "node_type": "1", "metadata": {}, "hash": "f008de771b9ee26c8da66ba163569abaf5f1bfef451564eaa4a39d560c372dc3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "4f3d8d56-7e65-4ef4-8ecc-37b2e470e243", "node_type": "1", "metadata": {}, "hash": "3fbaec4522fdcc448543aba4aca86f58eba0d86f3bfdfdb905dff8d89db572e3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Each  party  shall  be responsible to the other for any violation of this Agreement by its own employees or consultants.\n\n4. Neither  party  may  print  or  copy,\n\n  in  whole  or  in  part,  any  documents  or  magnetic media containing any Confidential Information without the prior written consent of the other party other than copies for employees or consultants who are working on the matter and have a need to know.\n\n5.", "mimetype": "text/plain", "start_char_idx": 1832, "end_char_idx": 2257, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "4f3d8d56-7e65-4ef4-8ecc-37b2e470e243": {"__data__": {"id_": "4f3d8d56-7e65-4ef4-8ecc-37b2e470e243", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "74cf7d14-80b5-4d6b-80da-768f0b10377c", "node_type": "1", "metadata": {}, "hash": "4c6fc8041fde1c5b1ebb27842236db2d449fcc1c265a1bddcc750bf9d2ddaa2d", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "81c81bee-9c4a-4831-ac6a-a156ea368de7", "node_type": "1", "metadata": {}, "hash": "beaf0e44b55cabb7cb7c87823cc7c17a7b7c88293857ad5f0d63193f0821c14a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Neither  party  may  use  the  other's  Confidential  Information  for  any  purpose  but  the Business Purpose stated above.\n\n6.\n\n Each  party's  Confidential  Information  shall  remain  its  own  property.", "mimetype": "text/plain", "start_char_idx": 2260, "end_char_idx": 2468, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "81c81bee-9c4a-4831-ac6a-a156ea368de7": {"__data__": {"id_": "81c81bee-9c4a-4831-ac6a-a156ea368de7", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "4f3d8d56-7e65-4ef4-8ecc-37b2e470e243", "node_type": "1", "metadata": {}, "hash": "3fbaec4522fdcc448543aba4aca86f58eba0d86f3bfdfdb905dff8d89db572e3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e7123a65-05bf-4099-854c-d93c5ec6d525", "node_type": "1", "metadata": {}, "hash": "e17a75d0d897097c0642cf01b4a7dd6fd7b8ab41189fc854fae5c1610c76328c", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Upon  the termination of the business relationship or upon request, whichever is sooner, each party  shall  return  all  of  the  other's  Confidential  Information,  certifying  destruction  of any copies or partial copies made.\n\n7.", "mimetype": "text/plain", "start_char_idx": 2470, "end_char_idx": 2703, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e7123a65-05bf-4099-854c-d93c5ec6d525": {"__data__": {"id_": "e7123a65-05bf-4099-854c-d93c5ec6d525", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "81c81bee-9c4a-4831-ac6a-a156ea368de7", "node_type": "1", "metadata": {}, "hash": "beaf0e44b55cabb7cb7c87823cc7c17a7b7c88293857ad5f0d63193f0821c14a", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "f307b2d9-43c0-4b1c-af5d-453d5236a0ab", "node_type": "1", "metadata": {}, "hash": "280e93e15854f7f9ca7a654ea1730fc8e851bdd263cbc1d29ba95328899dc43a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The  obligation  of  confidentiality  shall  extend  to  three  years  from  and  including  the date  of  return  of  the  Confidential  Information  and  certification  of  destruction  of  any copies made. At any time, either party may notify the other party in writing that future disclosures shall not be governed by this Agreement.\n\n8. If  either  party  becomes  legally  obligated,", "mimetype": "text/plain", "start_char_idx": 2706, "end_char_idx": 3095, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f307b2d9-43c0-4b1c-af5d-453d5236a0ab": {"__data__": {"id_": "f307b2d9-43c0-4b1c-af5d-453d5236a0ab", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "b229c36d-e9d9-4dd6-8ff0-92b60b4cbfda", "node_type": "4", "metadata": {}, "hash": "7441832893af7232dcdc6c343251c9c4f1462b9770dec7791f9dbe93a969e06b", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e7123a65-05bf-4099-854c-d93c5ec6d525", "node_type": "1", "metadata": {