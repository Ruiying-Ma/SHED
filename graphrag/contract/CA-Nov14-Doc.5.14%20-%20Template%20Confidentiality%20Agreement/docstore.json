f90effc0a", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "2612c3b7-c8ad-4acb-bc7d-434cef724e63", "node_type": "1", "metadata": {}, "hash": "5fd79d6c1525273e4f080aec91041a0a38edc0f87c9a1f54c7c40ea17bd80ee3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Each  Party  shall  require  that  its  external  experts  and/or consultants also have such policies and procedures in place to ensure their compliance with these confidentiality obligations.\n\nc.\n\n The obligations specified in this Article shall not apply to Information for which the receiving Party can reasonably demonstrate that such Information:\n\ni.\n\n was known to the receiving Party on a non-confidential basis prior to its disclosure pursuant to this Agreement;\n\nii.", "mimetype": "text/plain", "start_char_idx": 3467, "end_char_idx": 3942, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "2612c3b7-c8ad-4acb-bc7d-434cef724e63": {"__data__": {"id_": "2612c3b7-c8ad-4acb-bc7d-434cef724e63", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "f66b03e4-84e7-4971-9c6e-c86263689be4", "node_type": "4", "metadata": {}, "hash": "bafd03d29670dc90ee6ebc101c218609bf0effcc397f2e3fd1bb79da5c2bec29", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "67c11a67-98db-4a73-a879-f2c8d29d30ac", "node_type": "1", "metadata": {}, "hash": "cfd7b143c0bd1d2c2d1cc8fa62efffaa00cefedbe949124ac2d87e2e47672526", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "479857ec-fb91-48fe-a330-683cf99e2cf6", "node_type": "1", "metadata": {}, "hash": "106a18c11c3494153ab659794e5abf1601b7ae1b732e8988f102a4518ed468cf", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "is  publicly  known  at  the  time  of  disclosure  or  thereafter  becomes  publicly  known without breach of the terms of this Agreement on the part of the receiving Party;\n\niii. becomes known to the receiving Party through disclosure by sources other than the disclosing Party,\n\n having a right to disclose such Information,\n\niv.\n\n was  independently  developed  by  the  receiving  Party  without  access  to  the disclosing Party\u2019s Information.", "mimetype": "text/plain", "start_char_idx": 3945, "end_char_idx": 4394, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "479857ec-fb91-48fe-a330-683cf99e2cf6": {"__data__": {"id_": "479857ec-fb91-48fe-a330-683cf99e2cf6", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "f66b03e4-84e7-4971-9c6e-c86263689be4", "node_type": "4", "metadata": {}, "hash": "bafd03d29670dc90ee6ebc101c218609bf0effcc397f2e3fd1bb79da5c2bec29", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "2612c3b7-c8ad-4acb-bc7d-434cef724e63", "node_type": "1", "metadata": {}, "hash": "5fd79d6c1525273e4f080aec91041a0a38edc0f87c9a1f54c7c40ea17bd80ee3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "7887b164-ad2e-4dc8-8bbf-5e763c6ff42d", "node_type": "1", "metadata": {}, "hash": "fe7554752d2c11ba88f22bb4829d3ac0852eb96402571a6fc040e8d3ec20a2a1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "3. Applicable law and arbitration\n\na.\n\n The Parties shall first attempt to settle amicably any dispute arising out of this Agreement. Any  dispute  that  cannot  be  settled  amicably  between  the  Parties  shall  be  exclusively resolved by arbitration. The arbitration rules of [ \u2026 ]  shall be applicable.  The place of any hearing shall be [ \u2026 ]  and the language of the arbitration shall be [ \u2026 ].", "mimetype": "text/plain", "start_char_idx": 4396, "end_char_idx": 4798, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "7887b164-ad2e-4dc8-8bbf-5e763c6ff42d": {"__data__": {"id_": "7887b164-ad2e-4dc8-8bbf-5e763c6ff42d", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "f66b03e4-84e7-4971-9c6e-c86263689be4", "node_type": "4", "metadata": {}, "hash": "bafd03d29670dc90ee6ebc101c218609bf0effcc397f2e3fd1bb79da5c2bec29", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "479857ec-fb91-48fe-a330-683cf99e2cf6", "node_type": "1", "metadata": {}, "hash": "106a18c11c3494153ab659794e5abf1601b7ae1b732e8988f102a4518ed468cf", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "749b950c-022d-42e3-87bb-5f8e886d4563", "node_type": "1", "metadata": {}, "hash": "49542e9a19f870ac3b7d4489488b833bde45a5fb8e14d54bfaa778f47f6de40a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "b. This  Agreement shall be governed  by the laws of  [ \u2026 ],\n\n without regard to any principle of conflict  or  choice  of  laws  that  would  cause  the  application  of  the  laws  of  any  other jurisdiction.\n\nc.\n\n If at any time any provision of this Agreement is or becomes invalid or illegal in any respect, this shall have no effect on the validity of the remaining contractual provisions.", "mimetype": "text/plain", "start_char_idx": 4800, "end_char_idx": 5196, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "749b950c-022d-42e3-87bb-5f8e886d4563": {"__data__": {"id_": "749b950c-022d-42e3-87bb-5f8e886d4563", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "f66b03e4-84e7-4971-9c6e-c86263689be4", "node_type": "4", "metadata": {}, "hash": "bafd03d29670dc90ee6ebc101c218609bf0effcc397f2e3fd1bb79da5c2bec29", "class_name": 