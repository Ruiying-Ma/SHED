32-80c2c7fe371d", "node_type": "1", "metadata": {}, "hash": "ec870a56959824bf602904c6ff96c6b9a1c227975fcb73141ab63099e3f22f9c", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "5163091e-b36e-4244-88f7-1166e4366153", "node_type": "1", "metadata": {}, "hash": "a28a2cb7f9971eb98518d1be878f8c14a99c31a9b1729b5a03fe4538fd3306aa", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Discloser intends to disclose information (the Confidential Information) to the Recipient for the purpose of recommendation of future land use of the decommissioned play area on Ship Street (the Purpose).\n\n2.\n\n  The Recipient undertakes not to use the Confidential Information for any purpose except the Purpose, without first obtaining the written agreement of the Discloser.\n\n3.\n\n  The Recipient undertakes to keep the Confidential Information secure and not to disclose it to any third party.\n\n4.", "mimetype": "text/plain", "start_char_idx": 241, "end_char_idx": 744, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "5163091e-b36e-4244-88f7-1166e4366153": {"__data__": {"id_": "5163091e-b36e-4244-88f7-1166e4366153", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "08527629-2575-4a55-8d0f-18bbcfa98a67", "node_type": "4", "metadata": {}, "hash": "55bb0658aaa4e187594a41d6d99c0f3f4c3710f2c51a84950f7fb5d5a30b9233", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "9e244bb8-a293-4aa8-a415-0f8583573810", "node_type": "1", "metadata": {}, "hash": "2fce4f3f823bfbdb96def3880ed8dec398e008e6a377ed3322545eed1efe9696", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "7f12af0d-3f1c-4b11-9df8-839d41797919", "node_type": "1", "metadata": {}, "hash": "228414136fd37117249ada73cc6d7dc896e256763844a5939aa94addddb66ba5", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The undertakings in clauses 2 and 3 above apply to all of the information disclosed by the Discloser to the Recipient, regardless of the way or form in which it is disclosed or recorded but they do not apply to:\n\na)  any information which is or in future comes into the public domain (unless as a result of the breach of this Agreement);", "mimetype": "text/plain", "start_char_idx": 748, "end_char_idx": 1085, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "7f12af0d-3f1c-4b11-9df8-839d41797919": {"__data__": {"id_": "7f12af0d-3f1c-4b11-9df8-839d41797919", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "08527629-2575-4a55-8d0f-18bbcfa98a67", "node_type": "4", "metadata": {}, "hash": "55bb0658aaa4e187594a41d6d99c0f3f4c3710f2c51a84950f7fb5d5a30b9233", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "5163091e-b36e-4244-88f7-1166e4366153", "node_type": "1", "metadata": {}, "hash": "a28a2cb7f9971eb98518d1be878f8c14a99c31a9b1729b5a03fe4538fd3306aa", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "3187a11b-3865-436e-9ca9-93867a06ec6c", "node_type": "1", "metadata": {}, "hash": "b3b31accb8f15f4448f7834467af8130221ee1944cb86b92852165eb48473275", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "or\n\nb)  any information which is already known to the Recipient and which was not subject to any obligation of confidence before it was disclosed to the Recipient by the Discloser.\n\n5.\n\n  Nothing in this Agreement will prevent the Recipient from making any disclosure of the Confidential Information required by law or by any competent authority.\n\n6.", "mimetype": "text/plain", "start_char_idx": 1088, "end_char_idx": 1438, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "c