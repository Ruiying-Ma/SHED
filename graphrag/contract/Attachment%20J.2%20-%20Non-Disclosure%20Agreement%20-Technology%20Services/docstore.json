{"docstore/ref_doc_info": {"e1477eb2-075b-475b-97c1-68b7872f0b98": {"node_ids": ["983b6e2d-44a8-493d-8cde-77fe914efbcc", "7b1ab28e-1d8f-4148-a951-56964aefd2f4", "73ca08b3-ad29-43c1-be50-ab9464302595", "49a7fd47-dca4-474b-ac65-68fd8a7183c6", "3492787c-ab9b-4d1b-af3d-4f67439816d9", "cbffad56-2e87-4ece-9725-326d64da1598", "323b3440-3891-42d5-bd55-4db83a71562d"], "metadata": {}}}, "docstore/data": {"983b6e2d-44a8-493d-8cde-77fe914efbcc": {"__data__": {"id_": "983b6e2d-44a8-493d-8cde-77fe914efbcc", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "7b1ab28e-1d8f-4148-a951-56964aefd2f4", "node_type": "1", "metadata": {}, "hash": "3d5f066783f70ef3991fa785d1828715338e858109fccf7482c7382d1cb5c153", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Attachment J.2 \u2013 Non-Disclosure Agreement \u2013 Contractor\n\nNON-DISCLOSURE AGREEMENT (Technology Services Vendors)\n\nThis Non-Disclosure Agreement (this \u201c Agreement \u201d), dated as of ________________, 20 , is made by and between ______________________________________________________________________ (the \u201c Contractor \u201d) and The Office of the Chief Administrative Officer of the U.S. House of Representatives (the \u201c CAO \u201d).", "mimetype": "text/plain", "start_char_idx": 0, "end_char_idx": 416, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "7b1ab28e-1d8f-4148-a951-56964aefd2f4": {"__data__": {"id_": "7b1ab28e-1d8f-4148-a951-56964aefd2f4", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "983b6e2d-44a8-493d-8cde-77fe914efbcc", "node_type": "1", "metadata": {}, "hash": "93161daabbea41128e61eb2b9746a00753b1005fad503539856740b729ba17df", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "73ca08b3-ad29-43c1-be50-ab9464302595", "node_type": "1", "metadata": {}, "hash": "927b4a85f672567d3ccbc80b7ebe991e0b7edf76dd0292597e4e7ca1e3248266", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Contractor is a prospective offeror of (1) correspondence management system or constituent relationship management software services, (2) computer hardware maintenance services, and/or (3) systems administration support services (collectively, \u201c Technology Services \u201d) to one or more offices within the U.S. House of Representatives (the \u201c House \u201d). As the contracting officer of the House, the CAO agrees to make available to the Contractor certain non-public, confidential and proprietary information about the House.", "mimetype": "text/plain", "start_char_idx": 419, "end_char_idx": 942, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "73ca08b3-ad29-43c1-be50-ab9464302595": {"__data__": {"id_": "73ca08b3-ad29-43c1-be50-ab9464302595", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "7b1ab28e-1d8f-4148-a951-56964aefd2f4", "node_type": "1", "metadata": {}, "hash": "3d5f066783f70ef3991fa785d1828715338e858109fccf7482c7382d1cb5c153", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "49a7fd47-dca4-474b-ac65-68fd8a7183c6", "node_type": "1", "metadata": {}, "hash": "42701cd3524e27f75ff23e28aabda9cdb90112119029a6b76d9810955d5d44c3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u201cConfidential Information\u201d means any information disclosed to the Contractor by the CAO or the House, including, but not limited to: (a) security practices, operational information, business plans, customer data, customer lists, customer names, designs, documents, drawings, engineering information, hardware configuration information, processes, products, product plans, research, services, specifications, software, source code and trade secrets;", "mimetype": "text/plain", "start_char_idx": 944, "end_char_idx": 1392, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "49a7fd47-dca4-474b-ac65-68fd8a7183c6": {"__data__": {"id_": "49a7fd47-dca4-474b-ac65-68fd8a7183c6", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "73ca08b3-ad29-43c1-be50-ab9464302595", "node_type": "1", "metadata": {}, "hash": "927b4a85f672567d3ccbc80b7ebe991e0b7edf76dd0292597e4e7ca1e3248266", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "3492787c-ab9b-4d1b-af3d-4f67439816d9", "node_type": "1", "metadata": {}, "hash": "188d375cc3ae54350a59e1808e2e15800921970e2c495aec9c4b3da221945ad1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "and (b) any other information designated (orally or in writing) as \u201cconfidential,\u201d \u201cproprietary\u201d or of such nature that a reasonable person would understand such information to be confidential to the CAO or the House.", "mimetype": "text/plain", "start_char_idx": 1393, "end_char_idx": 1610, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "3492787c-ab9b-4d1b-af3d-4f67439816d9": {"__data__": {"id_": "3492787c-ab9b-4d1b-af3d-4f67439816d9", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "49a7fd47-dca4-474b-ac65-68fd8a7183c6", "node_type": "1", "metadata": {}, "hash": "42701cd3524e27f75ff23e28aabda9cdb90112119029a6b76d9810955d5d44c3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "cbffad56-2e87-4ece-9725-326d64da1598", "node_type": "1", "metadata": {}, "hash": "dbb4db7f5fe246352a056f34a5792e8c031102a9e119ade28084fa3d16fa49f1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Contractor agrees that hereafter it shall (i) treat all Confidential Information confidentially, and (ii) use the Confidential Information solely for the purpose of evaluating the possible procurement of Technology Services (and, if such procurement is made, for the purpose of performing such Technology Services). The Contractor further agrees to require each of its employees and agents to sign a form that would bind them in writing to protect the confidentiality of such Confidential Information.", "mimetype": "text/plain", "start_char_idx": 1612, "end_char_idx": 2117, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "cbffad56-2e87-4ece-9725-326d64da1598": {"__data__": {"id_": "cbffad56-2e87-4ece-9725-326d64da1598", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "3492787c-ab9b-4d1b-af3d-4f67439816d9", "node_type": "1", "metadata": {}, "hash": "188d375cc3ae54350a59e1808e2e15800921970e2c495aec9c4b3da221945ad1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "323b3440-3891-42d5-bd55-4db83a71562d", "node_type": "1", "metadata": {}, "hash": "f971cc2555c8fdc4a021edac1799ecd30b9d748402bea41276a842e5cbb8da6e", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "All documents containing Confidential Information and all copies thereof shall be promptly returned to the CAO upon the CAO\u2019s request.The Contractor understands that the CAO may seek any remedy available to it to ensure compliance with this Agreement, including, but not limited to, application for a court order prohibiting the disclosure of Confidential Information and/or disqualification from the solicitation and contracting process.", "mimetype": "text/plain", "start_char_idx": 2120, "end_char_idx": 2558, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "323b3440-3891-42d5-bd55-4db83a71562d": {"__data__": {"id_": "323b3440-3891-42d5-bd55-4db83a71562d", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "e1477eb2-075b-475b-97c1-68b7872f0b98", "node_type": "4", "metadata": {}, "hash": "d8add8e404f70028cb7491a3401b9622b425a9a5f4efdb153c50757c943b13ba", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "cbffad56-2e87-4ece-9725-326d64da1598", "node_type": "1", "metadata": {}, "hash": "dbb4db7f5fe246352a056f34a5792e8c031102a9e119ade28084fa3d16fa49f1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The Contractor agrees that if the terms and conditions of this Agreement are violated, the Contractor and its employees and agents may be subject to administrative, civil or criminal action.\n\nTHE OFFICE OF THE CHIEF ADMINISTRATIVE OFFICER OF THE U.S. HOUSE OF REPRESENTATIVES\n\nCONTRACTOR ______________________________________________ By:  ______________________________________________________ Name: Title: 1/27/12 NDA-1", "mimetype": "text/plain", "start_char_idx": 2561, "end_char_idx": 2982, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}}, "docstore/metadata": {"983b6e2d-44a8-493d-8cde-77fe914efbcc": {"doc_hash": "93161daabbea41128e61eb2b9746a00753b1005fad503539856740b729ba17df", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "7b1ab28e-1d8f-4148-a951-56964aefd2f4": {"doc_hash": "3d5f066783f70ef3991fa785d1828715338e858109fccf7482c7382d1cb5c153", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "73ca08b3-ad29-43c1-be50-ab9464302595": {"doc_hash": "927b4a85f672567d3ccbc80b7ebe991e0b7edf76dd0292597e4e7ca1e3248266", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "49a7fd47-dca4-474b-ac65-68fd8a7183c6": {"doc_hash": "42701cd3524e27f75ff23e28aabda9cdb90112119029a6b76d9810955d5d44c3", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "3492787c-ab9b-4d1b-af3d-4f67439816d9": {"doc_hash": "188d375cc3ae54350a59e1808e2e15800921970e2c495aec9c4b3da221945ad1", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "cbffad56-2e87-4ece-9725-326d64da1598": {"doc_hash": "dbb4db7f5fe246352a056f34a5792e8c031102a9e119ade28084fa3d16fa49f1", "ref_doc_id": "e1477eb2-075b-475b-97c1-68b7872f0b98"}, "323b3440-3891-42d5-bd55-4db83a71562d": {"doc_hash": "f971cc2555c8fdc4a021edac1799ecd30b9d748402bea41276a842e5cbb8da6e", "ref_doc_id": "e1477eb2-075b-475b-97c1-6