data": {}, "hash": "68dcf50ce02a113eedd83d61d3402c0dc93b7a8b23e0d89c158d308a70f639f1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "f0d5ea68-4ed3-4269-a82d-79a68dcd2e5b", "node_type": "1", "metadata": {}, "hash": "03c7fac621ac0b9a036c4a9f586f55f02cbfb5d4c3e0dd958a55dda16f4540a1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "WHEREAS the Recipient is bound to get to know about the Confidential Information in  pursuant  to  the  terms of  the  Agreement  for  the  purpose  of  supply,  installation, testing and commissioning of a CCTV System (hereinafter called as \"Purpose\") in the (hereinafter called as \"Premises\");", "mimetype": "text/plain", "start_char_idx": 667, "end_char_idx": 962, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f0d5ea68-4ed3-4269-a82d-79a68dcd2e5b": {"__data__": {"id_": "f0d5ea68-4ed3-4269-a82d-79a68dcd2e5b", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "71d5969d-71e7-49a1-83f1-eb1b867e884e", "node_type": "4", "metadata": {}, "hash": "368fce13f3dc6c0b562c9384dfc467ec2ebaaa15e2cfbf1c87cfdfa010263c97", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "fffddeb4-5860-4a58-af2d-1c6d5d2a4fb5", "node_type": "1", "metadata": {}, "hash": "93a908fef9d7208189dee652ab91561f30c41ddbb6a77c4f44819a7c72206736", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "8c8f726c-1b12-4060-972e-87a315fffdc0", "node_type": "1", "metadata": {}, "hash": "a62fd841f0c91bb3b7c3019630040af08d39fa80bb64e7e7c2507cac5bc500ae", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "NOW THEREFORE, in consideration for the mutual undertakings of the Discloser and the Recipient under this Agreement, the Parties agree as follows:\n\n1.", "mimetype": "text/plain", "start_char_idx": 965, 