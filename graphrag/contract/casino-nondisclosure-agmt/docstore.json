04077202ef74df9b8d5c2c9bc65d", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "0d8cd7cd-6f71-4ab2-8a4b-6e149648ced4", "node_type": "1", "metadata": {}, "hash": "eb52994e99e768e83024a8ffde83d52c2a35c3c0306d4dede48802c8bc270411", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "\u201cConfidential Information\u201d means any and all confidential and/or proprietary information disclosed by the Casino to the Receiving Party, which may include without limitation:  financial information, business information, marketing data, trade secrets, and other data, materials, products, plans, specifications, reports, manuals, computer software or programs, contractual relationships and other similar information delivered in any form or media.2.", "mimetype": "text/plain", "start_char_idx": 780, "end_char_idx": 1230, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "0d8cd7cd-6f71-4ab2-8a4b-6e149648ced4": {"__data__": {"id_": "0d8cd7cd-6f71-4ab2-8a4b-6e149648ced4", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "1835121b-9d60-4193-80f3-7cd355d03b51", "node_type": "1", "metadata": {}, "hash": "f64f3971237eb0b8c97b2a623e0e1375cdfcea8234af850a4c6e280fbd02dd16", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "d5252dac-229b-45fe-8101-d1146cfc8c96", "node_type": "1", "metadata": {}, "hash": "b4ae75d80a2f898a7d9fcece1c15b5f40cc9158eb18fdc81edb9ea19f7c7fb64", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Confidential Information is disclosed to Receiving Party solely for the purpose of providing services for the Project.\n\n  Receiving Party agrees to hold such Confidential Information in strict confidence.  Receiving Party agrees not to use, divulge, reproduce or otherwise make available the Confidential Information other than for the purposes of the Project and to disclose it only to its officers, agents, employees, partners, and professional advisors as necessary, who shall also be bound to comply with this Agreement.3.", "mimetype": "text/plain", "start_char_idx": 1231, "end_char_idx": 1757, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d5252dac-229b-45fe-8101-d1146cfc8c96": {"__data__": {"id_": "d5252dac-229b-45fe-8101-d1146cfc8c96", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "0d8cd7cd-6f71-4ab2-8a4b-6e149648ced4", "node_type": "1", "metadata": {}, "hash": "eb52994e99e768e83024a8ffde83d52c2a35c3c0306d4dede48802c8bc270411", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "1a154e51-7976-4e4a-b494-e0fb72ae0469", "node_type": "1", "metadata": {}, "hash": "a5d0bdd284d522ae797bd988cd238e8a6980bf13038f6f075a20b639704afae3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Receiving Party shall protect the Confidential Information with at least the same degree of care that it uses to protect its own confidential information, but in no case, less than reasonable care.4. Receiving Party will immediately notify the Casino upon the discovery of any loss or unauthorized disclosure of the Confidential Information.5.\n\n Receiving Party shall have no obligations under this Agreement with respect to Confidential Information if it can demonstrate that the information:  (a) is publicly available at the time of disclosure;", "mimetype": "text/plain", "start_char_idx": 1760, "end_char_idx": 2307, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1a154e51-7976-4e4a-b494-e0fb72ae0469": {"__data__": {"id_": "1a154e51-7976-4e4a-b494-e0fb72ae0469", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "d5252dac-229b-45fe-8101-d1146cfc8c96", "node_type": "1", "metadata": {}, "hash": "b4ae75d80a2f898a7d9fcece1c15b5f40cc9158eb18fdc81edb9ea19f7c7fb64", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "d9d4d734-c448-4316-9731-ad2209b77b5a", "node_type": "1", "metadata": {}, "hash": "3cbaafa317413984c2c1d06b65b13dd5d0f22774d6369218c0f8de3c17e761ee", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "(b) becomes publicly available after disclosure through no act of the receiving party or its representatives; (c) is in the receiving party\u2019s possession free of obligation; (d) is developed by the receiving party without use of the Confidential Information or through other breach of this Agreement; (e) is disclosed to the receiving party by a third party without obligation; (e) is not identifiable as confidential;", "mimetype": "text/plain", "start_char_idx": 2308, "end_char_idx": 2725, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d9d4d734-c448-4316-9731-ad2209b77b5a": {"__data__": {"id_": "d9d4d734-c448-4316-9731-ad2209b77b5a", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "1a154e51-7976-4e4a-b494-e0fb72ae0469", "node_type": "1", "metadata": {}, "hash": "a5d0bdd284d522ae797bd988cd238e8a6980bf13038f6f075a20b639704afae3", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "0c1327a0-c50a-4192-840a-b7ca64fdf609", "node_type": "1", "metadata": {}, "hash": "00d471590f93ca7ca542291ad22a18fd67049834df26ead6a76405c4b677e20c", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "or (f) is required to be publicly disclosed pursuant to a properly executed subpoena or other regulatory or court order (\u201cOrder\u201d), provided the receiving party (i) gives reasonable written notice to the disclosing party, (ii) gives the disclosing party a reasonable opportunity to respond to the Order, and (iii) limits disclosure to that portion of the Confidential Information required by the Order.\n\nPage 1\nRevised 06/27/2017\n6.", "mimetype": "text/plain", "start_char_idx": 2726, "end_char_idx": 3157, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "0c1327a0-c50a-4192-840a-b7ca64fdf609": {"__data__": {"id_": "0c1327a0-c50a-4192-840a-b7ca64fdf609", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "d9d4d734-c448-4316-9731-ad2209b77b5a", "node_type": "1", "metadata": {}, "hash": "3cbaafa317413984c2c1d06b65b13dd5d0f22774d6369218c0f8de3c17e761ee", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e22dfb3e-c1be-