x": 3745, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "c94408f0-586f-422d-bd58-bd5c1548caa3": {"__data__": {"id_": "c94408f0-586f-422d-bd58-bd5c1548caa3", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4", "metadata": {}, "hash": "9e8d6112fa6e6b63a0ea3864f6bc344d95c13f13857f6e4574703bff3a247e5c", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e22dfb3e-c1be-48b6-a4eb-6c9d52799446", "node_type": "1", "metadata": {}, "hash": "13289dd8dd9557902434924e67ca7306c556a4d6dbc64e02a09b1b6710ef166f", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "82f757fe-f783-4b6e-8699-3d427927ce07", "node_type": "1", "metadata": {}, "hash": "057b3c38ed34dd8e6b85b8a6b37d1052cd8c108c3ddf64905ed13093eead9472", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Neither party nor any of its representatives shall contact, either directly or indirectly, any governmental official, lender or other third party (other than a representative as provided herein) to discuss the Project or the business or the assets of the other party, or a potential business transaction with or concerning the other party, without first obtaining the written consent of the other party.8. Waiver of any provision of this Agreement must be made in writing.", "mimetype": "text/plain", "start_char_idx": 3749, "end_char_idx": 4221, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "82f757fe-f783-4b6e-8699-3d427927ce07": {"__data__": {"id_": "82f757fe-f783-4b6e-8699-3d427927ce07", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d941fda8-d0f4-46d6-a67f-d665482390d5", "node_type": "4"