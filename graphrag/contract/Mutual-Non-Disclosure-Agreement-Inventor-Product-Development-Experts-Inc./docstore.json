45c7a7e", "node_type": "1", "metadata": {}, "hash": "215d941e604b9918a345ce6590c4ba3b8b39d91c64ed72155a7a2d214658efb6", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "b8d551c0-fde6-4367-a1f2-d5c11b14bfa4", "node_type": "1", "metadata": {}, "hash": "51309fbc231b9400f95c447c108a8a2539fe0dd386b48b5a41f9b85b81d2b17c", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Information communicated  orally  shall  be  considered  Confidential  Information  if  such  information  is  confirmed  in  writing  as being Confidential Information within a reasonable time after the initial disclosure.  Confidential Information may also  include  information  disclosed  to  a  disclosing  party  by  third  parties.\n\n    Confidential  Information  shall  not, however,", "mimetype": "text/plain", "start_char_idx": 1317, "end_char_idx": 1708, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "b8d551c0-fde6-4367-a1f2-d5c11b14bfa4": {"__data__": {"id_": "b8d551c0-fde6-4367-a1f2-d5c11b14bfa4", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "aa9ea267-7cde-4da2-8968-db16b000cbdd", "node_type": "1", "metadata": {}, "hash": "620a3f192655a53ffb866add9f0b83d17e58fde4c3ea7a7b00aa3d93897cf8eb", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "ff63d988-30db-4865-bef2-93516d779c94", "node_type": "1", "metadata": {}, "hash": "422e75aef542e2e7d0ffc158a949d2d34334ef2ae7ef36369c556165eb3d8fb1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "include any information which (i) was publicly known and made generally available in the public domain prior to the time of disclosure by the disclosing party; (ii) becomes publicly known and made generally available after disclosure by the disclosing party to the receiving party through no action or inaction of the receiving party; (iii) is already in the possession of the receiving party at the time of disclosure by the disclosing party as shown by the receiving party's files and records immediately prior to the time of disclosure;", "mimetype": "text/plain", "start_char_idx": 1709, "end_char_idx": 2248, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "ff63d988-30db-4865-bef2-93516d779c94": {"__data__": {"id_": "ff63d988-30db-4865-bef2-93516d779c94", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "b8d551c0-fde6-4367-a1f2-d5c11b14bfa4", "node_type": "1", "metadata": {}, "hash": "51309fbc231b9400f95c447c108a8a2539fe0dd386b48b5a41f9b85b81d2b17c", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "0972e6bf-a572-496f-bc08-794992e7227e", "node_type": "1", "metadata": {}, "hash": "9dfe5a7d4046a8a2262d94993af603c18f0e2126d17ed325a856d1ffb93ad3e1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "(iv) is obtained by the receiving party from a third party without a breach of such third party's obligations of confidentiality; (v) is independently developed by the receiving party without use of or reference to the disclosing party's Confidential Information, as shown by documents and other competent evidence in the receiving party's possession;  or (vi) is required by law to be disclosed by the receiving party,", "mimetype": "text/plain", "start_char_idx": 2249, "end_char_idx": 2668, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "0972e6bf-a572-496f-bc08-794992e7227e": {"__data__": {"id_": "0972e6bf-a572-496f-bc08-794992e7227e", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "ff63d988-30db-4865-bef2-93516d779c94", "node_type": "1", "metadata": {}, "hash": "422e75aef542e2e7d0ffc158a949d2d34334ef2ae7ef36369c556165eb3d8fb1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "f8b8ba96-baff-4814-8acc-4ec483b808b7", "node_type": "1", "metadata": {}, "hash": "6c5c3c5c50e95dfd1883e78daccb8737f64c0122a1713f77491c32374acea7e7", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "provided that the receiving party gives the disclosing party prompt written notice of such requirement prior to such disclosure and assistance in obtaining an order protecting the information from public disclosure.\n\nNon-use  and  Non-disclosure.", "mimetype": "text/plain", "start_char_idx": 2669, "end_char_idx": 2915, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f8b8ba96-baff-4814-8acc-4ec483b808b7": {"__data__": {"id_": "f8b8ba96-baff-4814-8acc-4ec483b808b7", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "0972e6bf-a572-496f-bc08-794992e7227e", "node_type": "1", "metadata": {}, "hash": "9dfe5a7d4046a8a2262d94993af603c18f0e2126d17ed325a856d1ffb93ad3e1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e4e59b4e-19f8-420f-ace1-0368a6bd0b69", "node_type": "1", "metadata": {}, "hash": "384a731993f5b396a0e9c6cf8676af3b992da0473146b5a4d35551c76b7cedb1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Each  party  shall  not  use  the  Confidential  Information  of  the  other  party  for  any purpose  except  to  evaluate  and  engage  in  discussions  concerning  a  potential  business  relationship  between  the parties.  Neither party shall disclose any Confidential Information of the other party to third parties.", "mimetype": "text/plain", "start_char_idx": 2919, "end_char_idx": 3241, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e4e59b4e-19f8-420f-ace1-0368a6bd0b69": {"__data__": {"id_": "e4e59b4e-19f8-420f-ace1-0368a6bd0b69", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "f8b8ba96-baff-4814-8acc-4ec483b808b7", "node_type": "1", "metadata": {}, "hash": "6c5c3c5c50e95dfd1883e78daccb8737f64c0122a1713f77491c32374acea7e7", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "1731a350-015b-492f-8d8e-4fedffbcc547", "node_type": "1", "metadata": {}, "hash": "3f109a6482bac23695f07dff8723925aa51a82d6128115d7c5d7cb4a54fdbff3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "If any party makes  copies  of  the  Confidential  Information  of  the  other  party,  such  copies  shall  also  constitute  Confidential Information  and  any  and  all  confidential  markings  on  such  documents  shall  be  maintained.", "mimetype": "text/plain", "start_char_idx": 3245, "end_char_idx": 3485, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1731a350-015b-492f-8d8e-4fedffbcc547": {"__data__": {"id_": "1731a350-015b-492f-8d8e-4fedffbcc547", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "ce12cc5b-4d1b-486c-9d29-dc0ce4a93691", "node_type": "4", "metadata": {}, "hash": "c05003228d445475a28d4339494b06b2b8ac5cf5ae336e9f4ab04501dd7553ed", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e4e59b4e-19f8-420f-ace1-0368a6bd0b69", "node_type": "1", "metadata": {}, "hash": "384a731993f5b396a0e9c6cf8676af3b992da0473146b5a4d35551c76b7cedb1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "e5c896b4-cae7-4c43-bfe9-9465ae92717c", "node_type": "1", "metadata": {}, "hash": "0500d262b30be5fd2c4e0caf8dc7ecc5113cbe88fdfc3910a6a7bf9331f6a4eb", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Neither  party  shall reverse engineer, disassemble or decompile any prototypes, software or other tangible objects which embody the other party's Confidential Information and which are provided to the party hereunder.Maintenance  of  Confidentiality.    Each  party  shall  take  reasonable  measures  to  protect  the  secrecy  of  and  avoid disclosure  and  unauthorized  use  of  the  Confidential  Information  of  the  other  party.", "mimetype": "text/plain", "start_char_idx": 3491, "end_char_idx": 3930, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "e5c896b4-cae7-4c43-bfe9-9465ae92717c": {"__data__": {"id_": "e5c896b4-cae7-4c43-bfe9-9465ae92717c", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], 