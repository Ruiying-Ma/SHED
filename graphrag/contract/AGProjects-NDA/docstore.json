afc6c4a92f2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "6c8b93f8-c552-4910-8851-986b9f01e613", "node_type": "1", "metadata": {}, "hash": "7dca200264154480f54cfa116918baf2b6cb3b3756b50300d2e8e5d7b74f2617", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "90dc69c0-1b64-45f5-ad2a-516c6633328d", "node_type": "1", "metadata": {}, "hash": "4d447ad16c95ef1de31b6ea7a28b07861eed6aafa0d430e0f770e7bac3572678", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Return .\n\n All CONFIDENTIAL INFORMATION supplied by the DISCLOSING PARTY hereunder and all copies thereof, in whole or in part and on all media, shall be returned to the DISCLOSING PARTY by the RECEIVING PARTY within thirty (30) days upon demand by the DISCLOSING PARTY .", "mimetype": "text/plain", "start_char_idx": 5338, "end_char_idx": 5609, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "90dc69c0-1b64-45f5-ad2a-516c6633328d": {"__data__": {"id_": "90dc69c0-1b64-45f5-ad2a-516c6633328d", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d21ac6bf-d859-492a-8854-9997c11f0d46", "node_type": "4", "metadata": {}, "hash": "9ed73d49e5fd74e4c0085f08bf7c370e79048a00c848f666f1c77afc6c4a92f2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "b2ff941f-c7f1-4b76-a83f-6699003b9558", "node_type": "1", "metadata": {}, "hash": "c96fe3ef7d345592f449aa5a3176d968cf480d71d97360c8ebe6b23d48f8a9a4", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "48e86352-4571-4b70-a61e-35432191d628", "node_type": "1", "metadata": {}, "hash": "dee2cd1f0c56e31728e81f03ce951a14f7d0ed818846ca22eb86e910c2f6004f", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "All other information and all copies thereof prepared by the RECEIVING PARTY based on the CONFIDENTIAL INFORMATION , shall be either promptly destroyed or returned to the DISCLOSING PARTY upon demand, as determined by the DISCLOSING PARTY within its sole discretion.\n\n10. Duration.", "mimetype": "text/plain", "start_char_idx": 5612, "end_char_idx": 5893, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "48e86352-4571-4b70-a61e-35432191d628": {"__data__": {"id_": "48e86352-4571-4b70-a61e-35432191d628", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d21ac6bf-d859-492a-8854-9997c11f0d46", "node_type": "4", "metadata": {}, "hash": "9ed73d49e5fd74e4c0085f08bf7c370e79048a00c848f666f1c77afc6c4a92f2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "90dc69c0-1b64-45f5-ad2a-516c6633328d", "node_type": "1", "metadata": {}, "hash": "4d447ad16c95ef1de31b6ea7a28b07861eed6aafa0d430e0f770e7bac3572678", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "a20ddbfe-9c42-48ce-a50a-3dc68ce3874e", "node_type": "1", "metadata": {}, "hash": "ed776a64a86e02d0d373f22b16ad1a9d55167abc00ecc6d21058f3bf623dc642", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "This Agreement shall apply to any CONFIDENTIAL INFORMATION that may have been provided to the RECEIVING PARTY prior to or after the date hereof, and shall continue to govern the delivery of CONFIDENTIAL INFORMATION until terminated by written notice from either party to the other, except that the obligations of the parties hereunder with regard to CONFIDENTIAL INFORMATION disclosed prior to termination shall continue for a period for two (2) years thereafter.\n\n11. Injunctive Relief .", "mimetype": "text/plain", "start_char_idx": 5896, "end_char_idx": 6384, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "a20ddbfe-9c42-48ce-a50a-3dc68c