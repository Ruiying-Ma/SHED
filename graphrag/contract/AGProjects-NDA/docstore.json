642", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "10ca9f87-1005-46ae-810c-737627944ad0", "node_type": "1", "metadata": {}, "hash": "8c60010cd011136dc55bcb0b3bdeb52de7c501f7b3fee3ac6d3ffc29d78118b0", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "In case of unauthorized use or disclosure of the CONFIDENTIAL INFORMATION , The DISCLOSING PARTY shall be entitled to liquidated damages in the amount of \u20ac 10 000 (ten thousand Euro) for each such use or disclosure.", "mimetype": "text/plain", "start_char_idx": 6733, "end_char_idx": 6948, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "10ca9f87-1005-46ae-810c-737627944ad0": {"__data__": {"id_": "10ca9f87-1005-46ae-810c-737627944ad0", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d21ac6bf-d859-492a-8854-9997c11f0d46", "node_type": "4", "metadata": {}, "hash": "9ed73d49e5fd74e4c0085f08bf7c370e79048a00c848f666f1c77afc6c4a92f2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "d5efb6d6-8e2f-45f1-abad-4b14dedd07ab", "node_type": "1", "metadata": {}, "hash": "23aca6745eed4cef92d39b04a896c8002dca5ff50806e0103ac996a35b80a8dc", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "b36bd502-366c-4c8d-b355-a1564195ccde", "node_type": "1", "metadata": {}, "hash": "c33ed54236fa3fc192c178f95ea9e2dbaa8a409dbbde3b45952f08ff793da1a3", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Notwithstanding the right to liquidated damages, the DISCLOSING PARTY has the right to take any measures available and to claim and receive a higher amount of compensation if the DISCLOSING PARTY can prove that the actual damage sustained will exceed the amount of liquidated damages.\n\n13. Definitive Agreement.", "mimetype": "text/plain", "start_char_idx": 6951, "end_char_idx": 7262, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "b36bd502-366c-4c8d-b355-a1564195ccde": {"__data__": {"id_": "b36bd502-366c-4c8d-b355-a1564195ccde", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d21ac6bf-d859-492a-8854-9997c11f0d46", "node_type": "4", "metadata": {}, "hash": "9ed73d49e5fd74e4c0085f08bf7c370e79048a00c848f666f1c77afc6c4a92f2", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "10ca9f87-1005-46ae-810c-737627944ad0", "node_type": "1", "metadata": {}, "hash": "8c60010cd011136dc55bcb0b3bdeb52de7c501f7b3fee3ac6d3ffc29d78118b0", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "d46a06aa-464d-4742-961b-94be73ddcea5", "node_type": "1", "metadata": {}, "hash": "e20501fe5193e597944711e8ddd443c5d93b074b375b45d327c66da9c50a7391", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The parties hereto agree that no contract or agreement between the parties shall be deemed to exist unless and until a final definitive agreement has been executed and\n3(4)\ndelivered to both parties.\n\n14. Miscellaneous .\n\n This Agreement shall be binding on the respective parties hereto and their successors and permitted assigns. This Agreement may be modified only in writing signed by both parties hereto.\n\n15. Governing law .", "mimetype": "text/plain", "start_char_idx": 7265, "end_char_idx": 7695, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "d46a06aa-464d-4742-961b-94be73ddcea5": {"__data__": {"id_": "d46a06aa-464d-4742-961b-94be73ddcea5", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "d21ac6bf-d859-492a-8854-9997c11f0d46", "node_type": "4", "metadata": {}, 