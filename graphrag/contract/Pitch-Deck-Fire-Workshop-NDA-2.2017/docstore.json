 "1", "metadata": {}, "hash": "05cded1ce329240422f6050567a8f807d64d0b4cda15acb2e7f382e38357335b", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "bd15b577-0300-4b9a-89a2-91c5277f1097", "node_type": "1", "metadata": {}, "hash": "856780ce4c7c3cdeadb9c9955e153ae5843732e71560cde1cb15f2753a7d7ea1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Purpose for Disclosure (\u201cBusiness Purpose\u201d):  Relevant information may be disclosed by the Disclosing Party to the Recipient during the course of activities of the event to collaboratively ensure that attendees fully understand and effectively utilize the training material. This agreement covers the entirety of the event and any and all information shared by any party at the event to any other party at the event or after the event.", "mimetype": "text/plain", "start_char_idx": 739, "end_char_idx": 1174, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "bd15b577-0300-4b9a-89a2-91c5277f1097": {"__data__": {"id_": "bd15b577-0300-4b9a-89a2-91c5277f1097", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "c268e2f3-8d98-4da7-befe-b841022c5f64", "node_type": "4", "metadata": {}, "hash": "66342d25c839fec2a19061a16f3916c9f0a149edb002efd8a08bed8e0445c777", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "17ca5a3b-b81e-4e5b-b67e-d1a4e849b07f", "node_type": "1", "metadata": {}, "hash": "1eb7672ac2b05b2814a654dd710cb335cf250456342acd8d97dd94cb7f2b46c4", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "f7fb3209-400c-4f5a-aea4-9958b6b4c7cd", "node_type": "1", "metadata": {}, "hash": "34d6f031b391f5e695c91705b70bdb0db0b0140619d4d5e4648e53a07e9da975", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "The information may be shared verbally, visually, in a document, via email or other digital forum.\n\n The Parties hereby agree as follows:\n1. For purposes of this Agreement, \"Confidential Information\" shall mean any and all non-public information, including, without limitation, technical, developmental, marketing, sales, operating, performance, cost, know-how, business plans, business methods, and process information, disclosed to the Recipient.", "mimetype": "text/plain", "start_char_idx": 1175, "end_char_idx": 1623, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "f7fb3209-400c-4f5a-aea4-9958b6b4c7cd": {"__data__": {"id_": "f7fb3209-400c-4f5a-aea4-9958b6b4c7cd", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "c268e2f3-8d98-4da7-befe-b841022c5f64", "node_type": "4", "metadata": {}, "hash": "66342d25c839fec2a19061a16f3916c9f0a149edb002efd8a08bed8e0445c777", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "bd15b577-0300-4b9a-89a2-91c5277f1097", "node_type": "1", "metadata": {}, "hash": "856780ce4c7c3cdeadb9c9955e153ae5843732e71560cde1cb15f2753a7d7ea1", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "fffe8ae0-8b70-431f-9556-16c6fec995b9", "node_type": "1", "metadata": {}, "hash": "602c8f5c88a40dd664110f75e8535cd50b5d10b349a858414e8eb7ac0471fcf1", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "For convenience, the Disclosing Party may, but is not required to, mark written Confidential Information with the legend \"Confidential\" or an equivalent designation.\n\n2. All Confidential Information disclosed to the Recipient will be used solely for the Business Purpose and for no other purpose whatsoever.", "mimetype": "text/plain", "start_char_idx": 1625, "end_char_idx": 1932, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__t