losure.6.    The validity, construction and enforceability of this Agreement shall be governed in all respects by the law of the state of Colorado.", "mimetype": "text/plain", "start_char_idx": 4121, "end_char_idx": 4571, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "000c55c5-e547-47c0-a418-fa1da6bfc350": {"__data__": {"id_": "000c55c5-e547-47c0-a418-fa1da6bfc350", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "c268e2f3-8d98-4da7-befe-b841022c5f64", "node_type": "4", "metadata": {}, "hash": "66342d25c839fec2a19061a16f3916c9f0a149edb002efd8a08bed8e0445c777", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "3ddc3463-da42-4b18-b2ed-2ba8bd5394c7", "node_type": "1", "metadata": {}, "hash": "162576777b76e1cb6df24ef59366eb29c9aa99f3ca3851f8618f75d4abbcab60", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "4d0c204b-7afa-4114-82dc-b121ee684b94", "node_type": "1", "metadata": {}, "hash": "ec1d331fbf0fdb579e9eacb628dae296f8176aa9058825cef2174fd5c7d9e42a", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "This Agreement may not be amended except in writing signed by a duly authorized representative of the respective Parties. This Agreement shall control in the event of a conflict with any other agreement between the Parties with respect to the subject matter hereof.IN WITNESS WHEREOF, the Parties have executed this Agreement as of the date first above written.Pitch Deck Fire confirms that this information has been made clear and publically available to all event attendees.", "mimetype": "text/plain", "start_char_idx": 4574, "end_char_idx": 5050, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "4d0c204b-7afa-4114-82dc-b121ee684b94": {"__data__": {"id_": "4d0c204b-7afa-4114-