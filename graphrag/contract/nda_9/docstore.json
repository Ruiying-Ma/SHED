latedNodeInfo"}, "2": {"node_id": "e09dd689-7a4e-4834-b593-b4969c373485", "node_type": "1", "metadata": {}, "hash": "7fa94aacc03253fc9087637da755136db9630e1dbcdb64524fc38ae527926da7", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "1bfc8ed9-0663-4257-82a3-fc9ef7907e94", "node_type": "1", "metadata": {}, "hash": "7948c5f74f6532b17ab2c8a32211097e8781a221d271a7715c4a57e036800016", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "Confidentiality\n\nEach party may use the information received from the other party hereunder and may provide such information to its parent corporation or any other subsidiaries thereof and their respective employees as applicable for their use  only  in connection with the Business Purpose.Each party agrees that, for a period of 5 years from receipt of information from the  other party hereunder,", "mimetype": "text/plain", "start_char_idx": 679, "end_char_idx": 1078, "metadata_seperator": "\n", "text_template": "{metadata_str}\n\n{content}", "class_name": "TextNode"}, "__type__": "1"}, "1bfc8ed9-0663-4257-82a3-fc9ef7907e94": {"__data__": {"id_": "1bfc8ed9-0663-4257-82a3-fc9ef7907e94", "embedding": null, "metadata": {}, "excluded_embed_metadata_keys": [], "excluded_llm_metadata_keys": [], "relationships": {"1": {"node_id": "9d87dbd0-62e8-4efb-956a-233687063b16", "node_type": "4", "metadata": {}, "hash": "2a05834e7a1407e0626453ba99cd6a5301d8852f2cf6b4a8b4e484e36a6638ff", "class_name": "RelatedNodeInfo"}, "2": {"node_id": "e04df2ec-473f-4a97-a447-b0ab73f9a08d", "node_type": "1", "metadata": {}, "hash": "4720f88a502fb4c669463d1bc70fa3ee6bb002fdc968e1d6e8e63015fb0ab33a", "class_name": "RelatedNodeInfo"}, "3": {"node_id": "2cf7d778-a45f-4221-8ad2-e8d3045461bd", "node_type": "1", "metadata": {}, "hash": "69cbcc6272461e2e6e7739222ce8fcfb6ed9d4993e32e6ca75fa4abe21954865", "class_name": "RelatedNodeInfo"}}, "metadata_template": "{key}: {value}", "metadata_separator": "\n", "text": "such